# 复制为 .env 后可覆盖默认端口（本地与服务器通用）
# cp .env.example .env

# pte-live 统一 Docker 网络（由 IM 项目定义，shop 项目 external 接入）
DOCKER_NETWORK_NAME=pte_live_net
PTE_LIVE_NETWORK=pte_live_net
PTE_LIVE_SUBNET=172.30.0.0/24
PTE_LIVE_GATEWAY=172.30.0.1
PTE_LIVE_MQ_PULSAR_IP=172.30.0.13
PTE_LIVE_API_IM_IP=172.30.0.20

# docker-compose.yaml（pte_live_im 应用端口）
WS_PORT=11510
HTTP_PORT=11511
RPC_PORT=11512

# 本地 Docker 配置文件
IM_CONFIG_FILE=./conf/app.yaml

# MQ 服务见 docker-compose.yaml
PULSAR_IMAGE=apachepulsar/pulsar:3.3.3
PULSAR_PORT=16650
PULSAR_HTTP_PORT=18080
